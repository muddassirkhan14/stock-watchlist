# Copy to .env and adjust. docker-compose reads these for `docker compose build` / `up`.

# --- Build-time only: pip → PyPI (docker-compose defaults trusted hosts for SSL inspection) ---
# Does NOT fix Yahoo Finance at runtime — use ./certs/ or docker/corp-ca/ for that.
# Full pip certificate verification on a normal network:
# BUILD_PIP_TRUSTED_HOST=strict

# --- Yahoo TLS in Docker (runtime) ---
# docker-compose defaults YAHOO_SSL_VERIFY=0 so price refresh works behind SSL inspection
# without installing certificates. Set to 1 on trusted networks for full verification.
# YAHOO_SSL_VERIFY=1

# --- Optional: trust corporate root CA instead of skipping verify (more secure) ---
# Place IT’s root as .crt or .pem under ./certs/ (mounted by compose; gitignored).
# Or add files under docker/corp-ca/ before build (see docker/corp-ca/README.txt).

# --- Optional: parallel Yahoo quote workers inside the container (default 6, max 16) ---
# REFRESH_WORKERS=6
